{
  "manifestVersion": 5,
  "id": "org.opendeviceio.indesign",
  "name": "OpenDeviceIO",
  "version": "0.1.0",
  "main": "index.html",
  "host": [
    { "app": "ID", "minVersion": "18.0" }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "odioPanel",
      "label": { "default": "OpenDeviceIO" },
      "minimumSize": { "width": 230, "height": 180 },
      "preferredDockedSize": { "width": 300, "height": 240 },
      "preferredFloatingSize": { "width": 320, "height": 260 }
    }
  ],
  "requiredPermissions": {
    "network": {
      "domains": ["https://opendeviceio.org", "https://*.opendeviceio.org", "http://localhost:3000"]
    },
    "localFileSystem": "fullAccess"
  }
}
