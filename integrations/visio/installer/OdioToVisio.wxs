<?xml version="1.0" encoding="utf-8"?>
<!--
  WiX v5 installer for the OpenDeviceIO Visio importer. Installs OdioToVisio.exe (+
  deps) per-user and adds a Start-menu shortcut. Run it with Visio open; it prompts
  for a device id and draws the block onto the active page. Build:

    dotnet tool install --global wix
    wix extension add -g WixToolset.UI.wixext
    wix build installer/OdioToVisio.wxs -d BinDir=bin/Release/net48 ^
      -ext WixToolset.UI.wixext -o OdioToVisio.msi

  NOTE: this ships the runnable tool, not an in-ribbon add-in. A VSTO/COM ribbon
  add-in is the polished UX but needs the Office/VSTO developer toolchain to build
  (see integrations/RELEASING.md). Not built/tested in this repo.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package Name="OpenDeviceIO Visio Importer"
           Manufacturer="OpenDeviceIO"
           Version="0.1.0"
           UpgradeCode="b8e4c2a0-3f1d-4c77-9a2e-5c7e9d4a22b2"
           Scope="perUser"
           Compressed="yes">
    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
    <MediaTemplate EmbedCab="yes" />
    <ui:WixUI Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />
    <Feature Id="Main" Title="OpenDeviceIO Visio Importer" Level="1">
      <ComponentGroupRef Id="App" />
    </Feature>
  </Package>

  <Fragment>
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="ProgramsDir" Name="Programs">
        <Directory Id="AppDir" Name="OdioToVisio" />
      </Directory>
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="MenuDir" Name="OpenDeviceIO" />
    </StandardDirectory>

    <ComponentGroup Id="App">
      <Component Directory="AppDir" Guid="*">
        <File Id="OdioToVisioExe" Source="!(bindpath.BinDir)\OdioToVisio.exe" />
      </Component>
      <Component Directory="AppDir" Guid="*">
        <File Source="!(bindpath.BinDir)\Newtonsoft.Json.dll" />
      </Component>
      <Component Directory="AppDir" Guid="*">
        <File Source="!(bindpath.BinDir)\Microsoft.Office.Interop.Visio.dll" />
      </Component>
      <Component Directory="MenuDir" Guid="*">
        <Shortcut Id="OdioToVisioShortcut"
                  Name="OpenDeviceIO Visio Importer"
                  Target="[#OdioToVisioExe]"
                  WorkingDirectory="AppDir" />
        <RemoveFolder Id="RemoveMenuDir" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\OpenDeviceIO\VisioImporter"
                       Name="installed" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
