<?xml version="1.0" encoding="utf-8"?>
<!--
  WiX v5 installer for the OpenDeviceIO AutoCAD add-in. Installs the auto-loading
  .bundle into the per-user ApplicationPlugins folder, so AutoCAD registers the
  ODIOIMPORT command on next launch. Build in CI (or VS) with the WiX dotnet tool:

    dotnet tool install --global wix
    wix extension add -g WixToolset.UI.wixext
    wix build installer/OdioImport.wxs ^
      -d BinDir=bin/Release/net48 -d MetaDir=. ^
      -ext WixToolset.UI.wixext -o OdioImport-autocad.msi

  ($BinDir = build output with OdioImport.dll + Newtonsoft.Json.dll; $MetaDir holds
  PackageContents.xml.) Not built/tested in this repo — see integrations/RELEASING.md.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package Name="OpenDeviceIO AutoCAD Import"
           Manufacturer="OpenDeviceIO"
           Version="0.1.0"
           UpgradeCode="6f2d1a40-7c2e-4b8a-9b1e-0d9a6e2c11a1"
           Scope="perUser"
           Compressed="yes">
    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <ui:WixUI Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <Feature Id="Main" Title="OpenDeviceIO AutoCAD Import" Level="1">
      <ComponentGroupRef Id="BundleFiles" />
    </Feature>
  </Package>

  <Fragment>
    <!-- %APPDATA%\Autodesk\ApplicationPlugins\OdioImport.bundle\ -->
    <StandardDirectory Id="AppDataFolder">
      <Directory Id="AutodeskDir" Name="Autodesk">
        <Directory Id="AppPluginsDir" Name="ApplicationPlugins">
          <Directory Id="BundleDir" Name="OdioImport.bundle">
            <Directory Id="ContentsDir" Name="Contents" />
          </Directory>
        </Directory>
      </Directory>
    </StandardDirectory>

    <ComponentGroup Id="BundleFiles">
      <Component Directory="BundleDir" Guid="*">
        <File Source="!(bindpath.MetaDir)\PackageContents.xml" />
      </Component>
      <Component Directory="ContentsDir" Guid="*">
        <File Source="!(bindpath.BinDir)\OdioImport.dll" />
      </Component>
      <Component Directory="ContentsDir" Guid="*">
        <File Source="!(bindpath.BinDir)\Newtonsoft.Json.dll" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
