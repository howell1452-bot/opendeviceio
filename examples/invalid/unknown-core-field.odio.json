{
  "$schema": "https://opendeviceio.org/schema/v0.1/device.schema.json",
  "odioVersion": "0.1.0",
  "id": "acme/widget",
  "device": { "manufacturer": "Acme", "model": "Widget" },
  "ports": [
    {
      "id": "hdmi-in",
      "direction": "input",
      "connector": "hdmi-type-a",
      "signals": [{ "domain": "video", "standard": "hdmi-2.0", "resolution": "4k" }]
    }
  ],
  "x-invalid-reason": "signal uses unknown non-x- field 'resolution' (should be 'maxResolution'); core objects forbid unknown fields."
}
