{
  "$schema": "https://opendeviceio.org/schema/v0.1/device.schema.json",
  "odioVersion": "0.1.0",
  "id": "acme/widget",
  "device": { "manufacturer": "Acme" },
  "ports": [
    {
      "id": "hdmi-in",
      "direction": "input",
      "connector": "hdmi-type-a",
      "link": { "type": "hdmi", "standard": "hdmi-2.0" },
      "signals": [{ "domain": "video", "transport": "hdmi" }]
    }
  ],
  "x-invalid-reason": "device.model is required but missing. Everything else is valid."
}
