{
  "name": "@opendeviceio/adapters",
  "version": "0.1.0",
  "description": "Adapters that convert validated OpenDeviceIO (.odio.json) documents into design-tool import formats. EasySchematic, AutoCAD-DXF, is fully implemented; AVCAD is a registered stub.",
  "license": "Apache-2.0",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://opendeviceio.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/howell1452-bot/opendeviceio.git",
    "directory": "packages/adapters"
  },
  "bugs": "https://github.com/howell1452-bot/opendeviceio/issues",
  "keywords": [
    "opendeviceio",
    "odio",
    "av",
    "easyschematic",
    "dxf",
    "cad",
    "adapter"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "odio-export": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "export": "node dist/cli.js"
  },
  "dependencies": {
    "@opendeviceio/sdk": "^0.1.0",
    "@tarikjabiri/dxf": "^2.8.9",
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
